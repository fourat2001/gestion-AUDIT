<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.DashboardController">
   <left>
      <VBox prefWidth="250.0" styleClass="sidebar" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER" prefHeight="80.0">
               <children>
                  <Label text="AuditPro" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#showReports" styleClass="nav-button" text="📑 Reports List" />
                  <Button fx:id="btnStatistics" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#showStatistics" styleClass="nav-button" text="📊 Analytics" />
                  <Button fx:id="btnAddRapport" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#showAddRapport" styleClass="nav-button" text="📝 New Report" />
                  <Button fx:id="btnAddQuestion" alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#showAddQuestion" styleClass="nav-button" text="❓ New Question" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Button alignment="BASELINE_LEFT" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="nav-button-logout" text="🚪 Logout" />
               </children>
               <padding>
                  <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <StackPane fx:id="contentArea" style="-fx-background-color: #f4f7f6;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </StackPane>
   </center>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblViewTitle" text="Dashboard Overview" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="Logged in as:" textFill="#7f8c8d" />
                  <Label fx:id="lblUserRole" text="Administrator" textFill="#2c3e50" style="-fx-font-weight: bold;" />
               </children>
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </HBox>
         </children>
      </HBox>
   </top>
</BorderPane>
