<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AddRapportController">
    <children>
        <VBox maxWidth="550.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
             <children>

        
        <Label text="Create New Audit Report" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox spacing="5.0">
            <Label text="Report Title" textFill="#34495e" />
            <TextField fx:id="tfTitle" promptText="e.g. Annual Quality Audit" style="-fx-background-radius: 5px; -fx-padding: 10px;" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Category (Type)" textFill="#34495e" />
            <ComboBox fx:id="cbType" maxWidth="Infinity" promptText="Select Category" style="-fx-background-radius: 5px; -fx-padding: 5px;" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Audit Date" textFill="#34495e" />
            <DatePicker fx:id="dpDate" maxWidth="Infinity" style="-fx-padding: 5px;" />
        </VBox>
        
        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <Label text="Description" textFill="#34495e" />
            <TextArea fx:id="taDescription" prefHeight="80.0" promptText="Describe the scope of the audit..." style="-fx-background-radius: 5px;" wrapText="true" />
        </VBox>

        <VBox spacing="5.0">
             <Label text="Exam Duration (Minutes)" textFill="#34495e" />
             <TextField fx:id="tfDuration" promptText="e.g. 60" style="-fx-background-radius: 5px; -fx-padding: 10px;" />
        </VBox>
        
        <Button fx:id="btnSave" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSaveAction" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Save Rapport" />
        
        <Label fx:id="lblStatus" textAlignment="CENTER" wrapText="true" />
             </children>
        </VBox>
    </children>
</VBox>
