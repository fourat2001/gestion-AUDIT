<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" spacing="40.0" styleClass="login-bg" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.LoginController">
   <children>
      <VBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Audit System" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Label>
            <Label text="Please select your role to continue" textFill="#ecf0f1">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <HBox alignment="CENTER" spacing="50.0">
         <children>
            <!-- Admin Card -->
            <VBox fx:id="adminCard" onMouseClicked="#handleAdminSelection" prefHeight="300.0" prefWidth="250.0" styleClass="glass-pane, role-card">
               <children>
                  <Label styleClass="role-icon" text="🛠" />
                  <Label styleClass="role-title" text="Administrator" />
                  <Label styleClass="role-desc" text="Full access to manage reports and audit questions." wrapText="true">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
            
            <!-- User Card -->
            <VBox fx:id="userCard" onMouseClicked="#handleUserSelection" prefHeight="300.0" prefWidth="250.0" styleClass="glass-pane, role-card">
               <children>
                  <Label styleClass="role-icon" text="👥" />
                  <Label styleClass="role-title" text="Consultant" />
                  <Label styleClass="role-desc" text="View existing reports and associated questions." wrapText="true">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
   </padding>
</VBox>
