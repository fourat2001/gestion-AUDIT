<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AddQuestionController">
    <children>
        <VBox maxWidth="500.0" spacing="25.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
             <children>

        <Label text="Add New Question" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox spacing="5.0">
            <Label text="Question Content" textFill="#34495e" />
            <TextField fx:id="tfContent" promptText="Enter the question here..." style="-fx-background-radius: 5px; -fx-padding: 10px;" />
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Question Type" textFill="#34495e" />
            <ComboBox fx:id="cbType" maxWidth="Infinity" promptText="Select Type" style="-fx-background-radius: 5px; -fx-padding: 5px;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="✅ Bonne Réponse (visible Admin uniquement)" textFill="#27ae60" />
            <TextField fx:id="tfBonneReponse" promptText="Entrer la bonne réponse officielle..." style="-fx-background-radius: 5px; -fx-padding: 10px; -fx-border-color: #27ae60; -fx-border-radius: 5;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="⏱ Temps Limite (Secondes)" textFill="#e67e22" />
            <TextField fx:id="tfTimeLimit" promptText="ex: 30" style="-fx-background-radius: 5px; -fx-padding: 10px; -fx-border-color: #e67e22; -fx-border-radius: 5;" />
        </VBox>
        
        <Button fx:id="btnAdd" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleAddAction" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px; -fx-background-radius: 5px; -fx-cursor: hand;" text="Add Question" />
        
        <Label fx:id="lblStatus" textAlignment="CENTER" wrapText="true" />
             </children>
        </VBox>
    </children>
</VBox>
