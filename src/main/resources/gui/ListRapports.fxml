<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ListRapportsController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>

      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <Label text="Audit Reports Management" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleGeneratePDF" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="📥 Générer PDF" />
         </children>
      </HBox>
      <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
        <items>
          <AnchorPane minHeight="0.0" minWidth="0.0">
                <children>
                   <VBox layoutX="10.0" layoutY="10.0" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                      <children>
                         <Label text="Audit Reports" textFill="#34495e">
                            <font>
                               <Font name="System Bold" size="16.0" />
                            </font>
                         </Label>
                         <TableView fx:id="tvRapports" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5px;">
                           <columns>
                             <TableColumn fx:id="colTitle" prefWidth="150.0" text="Title" />
                               <TableColumn fx:id="colType" prefWidth="100.0" text="Category" />
                             <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
                           </columns>
                            <columnResizePolicy>
                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                         </TableView>
                      </children>
                   </VBox>
                </children>
             </AnchorPane>
          <AnchorPane minHeight="0.0" minWidth="0.0">
                <children>
                   <VBox layoutX="10.0" layoutY="10.0" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                      <children>
                         <Label text="Associated Questions" textFill="#34495e">
                            <font>
                               <Font name="System Bold" size="16.0" />
                            </font>
                         </Label>
                         <TableView fx:id="tvQuestions" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5px;">
                           <columns>
                             <TableColumn fx:id="colQuestionContent" prefWidth="160.0" text="Question" />
                             <TableColumn fx:id="colBonneReponse" prefWidth="150.0" text="✅ Bonne Réponse" />
                             <TableColumn fx:id="colAuditResponse" prefWidth="150.0" text="Réponse User" />
                             <TableColumn fx:id="colScore" prefWidth="110.0" text="📊 Score" />
                             <TableColumn fx:id="colActions" prefWidth="80.0" text="Actions" />
                           </columns>
                            <columnResizePolicy>
                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                         </TableView>
                         <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                               <Label fx:id="lblSummary" text="Select a report to see questions" textFill="#7f8c8d" />
                               <Region HBox.hgrow="ALWAYS" />
                               <Label fx:id="lblScore" text="" textFill="#2c3e50" style="-fx-font-weight: bold; -fx-font-size: 13;" visible="false" />
                               <Button fx:id="btnCalculerScore" mnemonicParsing="false" onAction="#handleCalculerScore" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="📊 Calculer Score" visible="false">
                                  <padding><Insets bottom="5.0" left="10.0" right="10.0" top="5.0" /></padding>
                               </Button>
                               <Button fx:id="btnStartAudit" mnemonicParsing="false" onAction="#handleStartAudit" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🚀 Start Audit session" visible="false">
                                  <padding>
                                     <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                                  </padding>
                               </Button>
                            </children>
                         </HBox>
                      </children>
                   </VBox>
                </children>
             </AnchorPane>
        </items>
      </SplitPane>
   </children>
</VBox>
